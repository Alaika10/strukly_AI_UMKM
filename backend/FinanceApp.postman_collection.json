			"item": [
				{
					"name": "Create Transaction",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const jsonData = pm.response.json();",
									"const id = jsonData.transactionId || jsonData.id;",
									"if (id) {",
									"  pm.environment.set('transactionId', id);",
									"}",
									"pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"transactionId is set\", () => pm.expect(id).to.not.be.undefined);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"category_id\": 1,\n  \"amount\": 150000,\n  \"merchant\": \"Alfamart\",\n  \"transaction_date\": \"2026-04-27\",\n  \"type\": \"expense\"\n}"
