        {
            "name": "Transactions",
            "auth": {
                "type": "bearer",
                "bearer": [
                    {
                        "key": "token",
                        "value": "{{accessToken}}",
                        "type": "string"
                    }
                ]
            },
            "item": [
                {
                    "name": "Create Transaction",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const jsonData = pm.response.json();",
                                    "const id = jsonData.transactionId || jsonData.id || (Array.isArray(jsonData) && jsonData[0]?.transactionId) || (Array.isArray(jsonData) && jsonData[0]?.id);",
                                    "if (id) {",
                                    "  pm.environment.set('transactionId', id);",
                                    "  pm.globals.set('transactionId', id);",
                                    "  pm.test('transactionId is set', () => pm.expect(id).to.be.a('number'));",
                                    "  console.log('transactionId saved:', id);",
                                    "} else if (jsonData.error) {",
                                    "  console.error('Create transaction error:', jsonData.error);",
                                    "  pm.test('create transaction response has no id', () => pm.expect.fail('No transactionId in response'));",
                                    "} else {",
                                    "  console.error('Create transaction response did not include id', jsonData);",
                                    "  pm.test('create transaction response did not include id', () => pm.expect.fail('No transactionId in response'));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"category_id\": 1,\n  \"amount\": 150000,\n  \"merchant\": \"Alfamart\",\n  \"transaction_date\": \"2026-04-27\",\n  \"type\": \"expense\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/transactions",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "transactions"]
                        }
                    }
                },
                {
                    "name": "Create Transaction from OCR",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const jsonData = pm.response.json();",
                                    "const id = jsonData.transactionId || jsonData.id || (Array.isArray(jsonData) && jsonData[0]?.transactionId) || (Array.isArray(jsonData) && jsonData[0]?.id);",
                                    "if (id) {",
                                    "  pm.environment.set('transactionId', id);",
                                    "  pm.globals.set('transactionId', id);",
                                    "  pm.test('transactionId is set', () => pm.expect(id).to.be.a('number'));",
                                    "  console.log('transactionId saved:', id);",
                                    "} else if (jsonData.error) {",
                                    "  console.error('Create OCR transaction error:', jsonData.error);",
                                    "  pm.test('create OCR transaction response has no id', () => pm.expect.fail('No transactionId in response'));",
                                    "} else {",
                                    "  console.error('Create OCR transaction response did not include id', jsonData);",
                                    "  pm.test('create OCR transaction response did not include id', () => pm.expect.fail('No transactionId in response'));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "file",
                                    "type": "file",
                                    "src": "upload/receipt.png"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/transactions/ocr",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "transactions", "ocr"]
                        }
                    }
                },
                {
                    "name": "Get All Transactions",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/transactions",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "transactions"]
                        }
                    }
                },
                {
                    "name": "Update Transaction",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "let transactionId = pm.environment.get('transactionId');",
                                    "if (!transactionId) {",
                                    "  transactionId = pm.globals.get('transactionId');",
                                    "  if (transactionId) {",
                                    "    pm.environment.set('transactionId', transactionId);",
                                    "    console.log('transactionId copied from globals to environment:', transactionId);",
                                    "  }",
                                    "}",
                                    "if (!transactionId) {",
                                    "  throw new Error('transactionId is not set. Run Create Transaction first or set transactionId in environment.');",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"merchant\": \"Updated Store\",\n  \"amount\": 175000\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "transactions", "{{transactionId}}"]
                        }
                    }
                },
                {
                    "name": "Delete Transaction",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "let transactionId = pm.environment.get('transactionId');",
                                    "if (!transactionId) {",
                                    "  transactionId = pm.globals.get('transactionId');",
                                    "  if (transactionId) {",
                                    "    pm.environment.set('transactionId', transactionId);",
                                    "    console.log('transactionId copied from globals to environment:', transactionId);",
                                    "  }",
                                    "}",
                                    "if (!transactionId) {",
                                    "  throw new Error('transactionId is not set. Run Create Transaction first or set transactionId in environment.');",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": ""
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "transactions", "{{transactionId}}"]
                        }
                    }
                }
            ]
